---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../lib/projects';
---

<BaseLayout title="Projects" description="Projects by Robin Linacre" width="wide">
  <article class="prose projects-intro">
    <h1>Projects</h1>
    <p>Things I have made.  Everything here is free and open source.</p>
  </article>

  <section class="project-grid" aria-label="Projects">
    {projects.map((project) => {
      const Description = project.description;
      const primaryUrl = project.liveUrl ?? project.githubUrl;

      return (
        <article class="project-card">
          <a class="project-image-link" href={primaryUrl} rel="noopener noreferrer" target="_blank">
            <Image
              class="project-image"
              src={project.image}
              alt=""
              widths={[480, 720, 960]}
              sizes="(max-width: 720px) calc(100vw - 2rem), 480px"
            />
          </a>

          <div class="project-card-body">
            <div class="project-card-main">
              <h2>
                <a href={primaryUrl} rel="noopener noreferrer" target="_blank">{project.name}</a>
              </h2>
              <div class="project-description">
                <Description />
              </div>
            </div>

            <div class="project-actions" aria-label={`${project.name} links`}>
              {project.liveUrl && (
                <a class="project-action primary" href={project.liveUrl} rel="noopener noreferrer" target="_blank">
                  <span>Open app</span>
                  <svg viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M11.5 3a.75.75 0 0 0 0 1.5h2.19l-6.22 6.22a.75.75 0 0 0 1.06 1.06l6.22-6.22v2.19a.75.75 0 0 0 1.5 0v-4A.75.75 0 0 0 15.5 3h-4Zm-6 2.5A2.5 2.5 0 0 0 3 8v6.5A2.5 2.5 0 0 0 5.5 17H12a2.5 2.5 0 0 0 2.5-2.5V11a.75.75 0 0 0-1.5 0v3.5a1 1 0 0 1-1 1H5.5a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1H9a.75.75 0 0 0 0-1.5H5.5Z" />
                  </svg>
                </a>
              )}
              {project.githubUrl && (
                <a class="project-action" href={project.githubUrl} rel="noopener noreferrer" target="_blank">
                  <span>GitHub</span>
                  <svg viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M11.5 3a.75.75 0 0 0 0 1.5h2.19l-6.22 6.22a.75.75 0 0 0 1.06 1.06l6.22-6.22v2.19a.75.75 0 0 0 1.5 0v-4A.75.75 0 0 0 15.5 3h-4Zm-6 2.5A2.5 2.5 0 0 0 3 8v6.5A2.5 2.5 0 0 0 5.5 17H12a2.5 2.5 0 0 0 2.5-2.5V11a.75.75 0 0 0-1.5 0v3.5a1 1 0 0 1-1 1H5.5a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1H9a.75.75 0 0 0 0-1.5H5.5Z" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </article>
      );
    })}
  </section>
</BaseLayout>

<style>
  .projects-intro {
    max-width: 65ch;
  }

  .projects-intro h1 {
    margin-bottom: 0.4rem;
  }

  .projects-intro p {
    color: var(--text-light);
    margin-bottom: 1.25rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 0 0 2.5rem;
  }

  .project-card {
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
    border: 1px solid var(--soft-line);
    border-radius: var(--radius);
    background: #fff;
    box-shadow: 0 1px 2px rgb(17 24 39 / 0.05);
    color: var(--text);
    transition:
      border-color 140ms ease,
      box-shadow 140ms ease,
      transform 140ms ease;
  }

  .project-card:hover,
  .project-card:focus-within {
    border-color: var(--line);
    box-shadow: 0 10px 24px rgb(17 24 39 / 0.08);
    transform: translateY(-1px);
  }

  .project-image-link {
    display: block;
    overflow: hidden;
    color: var(--text);
    line-height: 0;
    text-decoration: none;
    background: transparent;
    border-bottom: 1px solid var(--soft-line);
    padding: 0.75rem;
  }

  .project-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    height: 100%;
    object-fit: contain;
    transition: transform 180ms ease;
  }

  .project-card:hover .project-image,
  .project-card:focus-within .project-image {
    transform: scale(1.015);
  }

  .project-card-body {
    display: grid;
    grid-template-rows: 1fr auto;
    gap: 0.9rem;
    padding: 1rem;
  }

  .project-card-main {
    display: grid;
    gap: 0.25rem;
    align-content: start;
  }

  .project-card h2 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    line-height: 1.3;
    margin: 0;
  }

  .project-description {
    color: var(--text-light);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .project-description :global(p),
  .project-description :global(ul),
  .project-description :global(ol) {
    margin: 0;
  }

  .project-description :global(p + p),
  .project-description :global(p + ul),
  .project-description :global(p + ol),
  .project-description :global(ul + p),
  .project-description :global(ol + p) {
    margin-top: 0.55rem;
  }

  .project-description :global(ul),
  .project-description :global(ol) {
    padding-left: 1.25rem;
  }

  .project-description :global(a) {
    color: var(--link);
  }

  .project-description :global(a:hover),
  .project-description :global(a:focus-visible) {
    color: var(--link-hover);
  }

  .project-card p {
    margin: 0;
    color: var(--text-light);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .project-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-height: 2rem;
    border: 1px solid var(--soft-line);
    border-radius: var(--radius);
    background: #fff;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.2;
    padding: 0.4rem 0.65rem;
  }

  .project-action svg {
    width: 0.95rem;
    height: 0.95rem;
    flex: none;
    fill: currentColor;
  }

  .project-action:hover,
  .project-action:focus-visible {
    border-color: var(--line);
    color: var(--link-hover);
    text-decoration: none;
  }

  .project-action.primary {
    border-color: var(--link);
    background: var(--link);
    color: #fff;
  }

  .project-action.primary:hover,
  .project-action.primary:focus-visible {
    border-color: var(--link-hover);
    background: var(--link-hover);
    color: #fff;
  }

  @media (max-width: 760px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
