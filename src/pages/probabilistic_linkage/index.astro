---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  probLinkageArticles,
  probLinkageCategoryOrder,
  probLinkageCategoryTitles,
} from '../../lib/probabilisticLinkage.js';
---

<BaseLayout
  title="Probabilistic Linkage Training"
  description="A set of interactive, explorable explanations of the Fellegi Sunter model, providing an introduction to probabilistic record linkage."
>
  <article class="prose">
    <h1>Probabilistic record linkage</h1>

    <p>
      These pages present some introductory training material on probabilistic record linkage using
      the Fellegi Sunter model. Many of the articles are interactive.
    </p>

    <p>
      This material presents a simplified version of the model used by
      {' '}<a href="https://github.com/moj-analytical-services/splink">Splink</a>, a piece of
      probabalistic linkage software for which I'm lead developer.
    </p>

    <p>
      Many of the graphics presented re-use Splink's graphical output, and the representation of
      model parameters used is the same as Splink's
      {' '}<a href="https://moj-analytical-services.github.io/splink_settings_editor/">settings object</a>.
    </p>

    <h2>Training materials on probabilistic linkage</h2>

    {probLinkageCategoryOrder.map((category) => {
      const articles = probLinkageArticles.filter((article) => article.category === category);
      if (articles.length === 0) return null;
      const ListTag = category === 'tutorial' ? 'ol' : 'ul';
      return (
        <section>
          <h3>{probLinkageCategoryTitles[category]}</h3>
          <ListTag>
            {articles.map((article) => (
              <li><a href={`/${article.slug}/`}>{article.title}</a></li>
            ))}
          </ListTag>
        </section>
      );
    })}

    <h2>Further reading (external links)</h2>
    <ol>
      <li>
        <a href="https://www.gov.uk/government/publications/joined-up-data-in-government-the-future-of-data-linking-methods/splink-mojs-open-source-library-for-probabilistic-record-linkage-at-scale">
          Splink: MoJ's open source library for probabilistic record linkage at scale
        </a>
      </li>
      <li><a href="https://github.com/moj-analytical-services/splink">Splink homepage</a></li>
      <li>
        <a href="https://mybinder.org/v2/gh/moj-analytical-services/splink_demos/master?urlpath=lab/tree/index.ipynb">
          Try Splink live in your browser
        </a>
      </li>
      <li><a href="https://www.robinlinacre.com/splink3_settings_editor_temp">Interactive settings editor</a></li>
    </ol>
  </article>
</BaseLayout>
