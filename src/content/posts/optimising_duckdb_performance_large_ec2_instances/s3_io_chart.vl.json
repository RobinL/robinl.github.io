      },
      "axis": {
        "title": null,
        "labelLimit": 420,
        "labelLineHeight": 14
      }
    },
    "x": {
      "type": "quantitative",
      "scale": {
        "domain": [
          0,
          18
        ]
      },
      "axis": {
        "title": "Time (seconds)",
        "format": ",.0f"
      }
    }
  },
  "layer": [
    {
      "data": {
        "name": "segments"
      },
      "mark": {
        "type": "bar",
        "size": 22
      },
      "encoding": {
        "x": {
          "field": "seconds",
          "stack": "zero"
        },
        "color": {
          "field": "segment_color_label",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": [
              "DuckDB -> S3 direct",
              "DuckDB -> local phase",
              "Local -> aws s3 sync phase"
            ],
            "range": [
              "#2563eb",
              "#0f766e",
              "#d97706"
            ]
          }
        },
        "order": {
          "field": "segment_order",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "option_label",
            "title": "Option",
            "type": "nominal"
          },
          {
            "field": "segment_label",
            "title": "Stage",
            "type": "nominal"
          },
          {
            "field": "seconds",
            "title": "Time (s)",
            "type": "quantitative",
            "format": ",.2f"
          },
          {
            "field": "throughput_mib_per_second",
            "title": "Throughput (MiB/s)",
            "type": "quantitative",
            "format": ",.1f"
          },
          {
            "field": "total_seconds",
            "title": "Total time (s)",
            "type": "quantitative",
            "format": ",.2f"
          },
          {
            "field": "total_throughput_mib_per_second",
            "title": "Overall throughput (MiB/s)",
            "type": "quantitative",
            "format": ",.1f"
          }
        ]
      }
    },
    {
      "data": {
        "name": "totals"
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "fontSize": 12,
        "fontWeight": 700,
        "color": "#111827"
      },
      "encoding": {
        "x": {
          "field": "label_position_seconds"
        },
        "y": {
          "field": "option_label",
          "type": "nominal",
          "sort": {
            "field": "option_order",
            "op": "min",
            "order": "ascending"
          },
          "axis": null
        },
        "text": {
          "field": "total_seconds_label"
        }
      }
    }
