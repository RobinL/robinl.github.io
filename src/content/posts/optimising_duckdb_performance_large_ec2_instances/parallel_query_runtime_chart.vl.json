        "labelLimit": 80,
        "labelLineHeight": 14
      }
    },
    "y": {
      "field": "max_query_seconds",
      "type": "quantitative",
      "title": "Slowest query runtime (seconds)",
      "scale": {
        "domain": [
          0,
          40
        ]
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 4,
        "cornerRadiusTopRight": 4,
        "size": 42
      },
      "encoding": {
        "color": {
          "field": "query_count_label",
          "type": "nominal",
          "scale": {
            "domain": [
              "1 query",
              "2 queries",
              "4 queries"
            ],
            "range": [
              "#2563eb",
              "#0f766e",
              "#d97706"
            ]
          }
        },
        "tooltip": [
          {
            "field": "config_label",
            "type": "nominal",
            "title": "Configuration"
          },
          {
            "field": "query_count",
            "type": "quantitative",
