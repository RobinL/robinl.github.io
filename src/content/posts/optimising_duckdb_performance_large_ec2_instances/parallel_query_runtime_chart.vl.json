            "type": "quantitative",
            "title": "Threads per query"
          },
          {
            "field": "total_threads",
            "type": "quantitative",
            "title": "Total possible threads"
          },
          {
            "field": "max_query_seconds",
            "type": "quantitative",
            "title": "Slowest query runtime (s)",
            "format": ".3f"
          },
          {
            "field": "avg_query_seconds",
            "type": "quantitative",
            "title": "Average query runtime (s)",
            "format": ".3f"
          },
          {
            "field": "sequential_query_seconds",
            "type": "quantitative",
            "title": "Sequential 32-thread runtime (s)",
            "format": ".3f"
          },
          {
            "field": "runtime_vs_sequential_label",
            "type": "nominal",
            "title": "Relative to sequential baseline"
          },
          {
            "field": "wall_seconds",
            "type": "quantitative",
            "title": "End-to-end phase time (s)",
            "format": ".3f"
          },
          {
            "field": "throughput_queries_per_second",
            "type": "quantitative",
            "title": "End-to-end throughput (queries/s)",
            "format": ".4f"
          },
          {
            "field": "avg_cpu_percent",
            "type": "quantitative",
            "title": "Average host CPU (%)",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "tick",
        "thickness": 3,
        "size": 24,
        "color": "#111827"
      },
      "encoding": {
        "y": {
          "field": "sequential_query_seconds",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "config_label",
            "type": "nominal",
            "title": "Configuration"
          },
          {
            "field": "sequential_query_seconds",
            "type": "quantitative",
            "title": "Sequential 32-thread runtime (s)",
            "format": ".3f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "top",
        "dy": 6,
        "fontSize": 12,
        "fontWeight": 700,
