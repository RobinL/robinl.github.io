{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Runtime comparison for the group/order query on raw Parquet files on r8id.metal-48xl.",
  "width": 450,
  "height": 220,
  "padding": {
    "left": 8,
    "right": 16,
    "top": 4,
    "bottom": 4
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "legend": {
      "orient": "bottom",
      "direction": "horizontal",
      "titleFontSize": 12,
      "labelFontSize": 12,
      "title": "Storage layout"
    }
  },
  "data": {
    "values": [
      {
        "storage_layout": "Parquet",
        "thread_count": 32,
        "query_seconds": 8.337,
        "runtime_label": "8.34s",
        "relative_to_fastest_layout": 1.31
      },
      {
        "storage_layout": "Parquet",
        "thread_count": 64,
        "query_seconds": 8.554,
        "runtime_label": "8.55s",
        "relative_to_fastest_layout": 1.35
      },
      {
        "storage_layout": "Parquet",
        "thread_count": 128,
        "query_seconds": 7.361,
        "runtime_label": "7.36s",
        "relative_to_fastest_layout": 1.16
      },
      {
        "storage_layout": "Parquet",
        "thread_count": 192,
        "query_seconds": 6.348,
        "runtime_label": "6.35s",
        "relative_to_fastest_layout": 1
      }
    ]
  },
  "encoding": {
    "x": {
      "field": "thread_count",
      "type": "ordinal",
      "title": "DuckDB threads",
      "sort": [
        32,
        64,
        128,
        192
      ],
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "query_seconds",
      "type": "quantitative",
      "title": "Runtime (seconds)",
      "scale": {
        "domain": [
          0,
          18
        ]
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 4,
        "cornerRadiusTopRight": 4,
        "size": 50
      },
      "encoding": {
        "xOffset": {
          "field": "storage_layout",
          "scale": {
            "paddingInner": 0,
            "paddingOuter": 0
          }
        },
        "color": {
          "field": "storage_layout",
          "type": "nominal",
          "scale": {
            "domain": [
              "Parquet"
            ],
            "range": [
              "#f58518"
            ]
          }
        },
        "tooltip": [
          {
            "field": "storage_layout",
            "type": "nominal",
            "title": "Storage"
          },
          {
            "field": "thread_count",
            "type": "ordinal",
            "title": "Threads"
          },
          {
            "field": "query_seconds",
            "type": "quantitative",
            "title": "Runtime (s)",
            "format": ".3f"
          },
          {
            "field": "relative_to_fastest_layout",
            "type": "quantitative",
            "title": "Relative to fastest for this storage",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "top",
        "dy": 6,
        "fontSize": 12,
        "fontWeight": 700,
        "color": "#ffffff"
      },
      "encoding": {
        "xOffset": {
          "field": "storage_layout",
          "scale": {
            "paddingInner": 0,
            "paddingOuter": 0
          }
        },
        "text": {
          "field": "runtime_label"
        }
      }
    }
  ],
  "title": "Results from r8id.metal-48xl"
}