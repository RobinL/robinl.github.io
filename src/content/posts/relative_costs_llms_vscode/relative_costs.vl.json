{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Grouped bar chart of GitHub Copilot model pricing rows, with interactive baseline selection and relative cost multiples.",
  "width": 1200,
  "height": 520,
  "params": [
    {
      "name": "baselineModelEffort",
      "value": "GPT-5.5 | medium",
      "bind": {
        "input": "select",
        "options": [
          "Claude Haiku 4.5 | not_supported",
          "Claude Opus 4.5 | not_supported",
          "Claude Opus 4.6 | low",
          "Claude Opus 4.6 | medium",
          "Claude Opus 4.6 | high",
          "Claude Opus 4.6 | x-high",
          "Claude Opus 4.7 | low",
          "Claude Opus 4.7 | medium",
          "Claude Opus 4.7 | high",
          "Claude Opus 4.7 | x-high",
          "Claude Opus 4.8 | low",
          "Claude Opus 4.8 | medium",
          "Claude Opus 4.8 | high",
          "Claude Opus 4.8 | x-high",
          "Claude Sonnet 4.5 | not_supported",
          "Claude Sonnet 4.6 | low",
          "Claude Sonnet 4.6 | medium",
          "Claude Sonnet 4.6 | high",
          "Claude Sonnet 4.6 | x-high",
          "Gemini 2.5 Pro | not_supported",
          "Gemini 3 Flash (Preview) | not_supported",
          "Gemini 3.1 Pro (Preview) | not_supported",
          "GPT-5 mini | not_supported",
          "GPT-5.2 | not_supported",
          "GPT-5.2-Codex | not_supported",
          "GPT-5.3-Codex | low",
          "GPT-5.3-Codex | medium",
          "GPT-5.3-Codex | high",
          "GPT-5.3-Codex | x-high",
          "GPT-5.4 | low",
          "GPT-5.4 | medium",
          "GPT-5.4 | high",
          "GPT-5.4 | x-high",
          "GPT-5.5 | low",
          "GPT-5.5 | medium",
          "GPT-5.5 | high",
          "GPT-5.5 | x-high"
        ],
        "name": "Baseline model / effort: "
      }
    },
    {
      "name": "costMetric",
      "value": "estimated_uncached_total_credits_for_1m_input_plus_medium_baseline_1m_output",
      "bind": {
        "input": "select",
        "options": [
          "estimated_uncached_total_credits_for_1m_input_plus_medium_baseline_1m_output",
          "estimated_cached_total_credits_for_1m_cached_input_plus_medium_baseline_1m_output",
          "estimated_output_credits_for_medium_baseline_1m_output_tokens",
          "output_credits_per_1m_tokens",
          "input_credits_per_1m_tokens",
          "cached_input_credits_per_1m_tokens"
        ],
        "labels": [
          "Total credits: 1M input + effort-adjusted output (uncached)",
          "Total credits: 1M cached input + effort-adjusted output",
          "Effort-adjusted output credits only",
          "Unit output credits only (no effort multiplier)",
          "Unit input credits only",
          "Unit cached-input credits only"
        ],
        "name": "Cost metric: "
      }
    },
    {
      "name": "showRecentModelsOnly",
      "value": true,
      "bind": {
        "input": "checkbox",
        "name": "Show recent models only: "
      }
    }
  ],
  "transform": [
    {
      "calculate": "datum.name + ' | ' + datum.reasoning_level",
      "as": "model_effort"
    },
    {
      "filter": "!showRecentModelsOnly || indexof(['Claude Haiku 4.5', 'Claude Opus 4.6', 'Claude Opus 4.7', 'Claude Opus 4.8', 'Claude Sonnet 4.5', 'Claude Sonnet 4.6', 'Gemini 3 Flash (Preview)', 'Gemini 3.1 Pro (Preview)', 'GPT-5.3-Codex', 'GPT-5.4', 'GPT-5.5'], datum.name) >= 0"
    },
    {
      "calculate": "datum[costMetric] * 1",
      "as": "selected_cost_credits"
    },
    {
      "calculate": "datum.model_effort === baselineModelEffort ? datum.selected_cost_credits : null",
      "as": "baseline_cost_candidate"
    },
    {
      "joinaggregate": [
        {
          "op": "max",
          "field": "baseline_cost_candidate",
          "as": "baseline_cost_credits"
        }
      ]
    },
    {
      "calculate": "datum.selected_cost_credits / datum.baseline_cost_credits",
      "as": "relative_multiple"
    },
    {
      "calculate": "datum.model_effort === baselineModelEffort ? 'selected baseline' : ''",
      "as": "baseline_flag"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "x": {
          "field": "name",
          "type": "nominal",
          "title": "Model",
          "sort": null,
          "axis": {
            "labelAngle": -35,
            "labelLimit": 180
          }
        },
        "xOffset": {
          "field": "reasoning_level",
          "type": "nominal",
          "sort": [
            "not_supported",
            "low",
            "medium",
            "high",
            "x-high"
          ]
        },
        "y": {
          "field": "relative_multiple",
          "type": "quantitative",
          "title": "Multiple of selected baseline",
          "axis": {
            "format": ".1f"
          }
        },
        "color": {
          "field": "reasoning_level",
          "type": "nominal",
          "title": "Reasoning level",
          "sort": [
            "not_supported",
            "low",
            "medium",
            "high",
            "x-high"
          ]
        },
        "opacity": {
          "condition": {
            "test": "datum.model_effort === baselineModelEffort",
            "value": 1
          },
          "value": 0.8
        },
        "tooltip": [
          {
            "field": "name",
            "type": "nominal",
            "title": "Model"
          },
          {
            "field": "provider",
            "type": "nominal",
            "title": "Provider"
          },
          {
            "field": "context_size",
            "type": "nominal",
            "title": "Context size"
          },
          {
            "field": "reasoning_level",
            "type": "nominal",
            "title": "Reasoning level"
          },
          {
            "field": "reasoning_token_multiplier_vs_medium",
            "type": "quantitative",
            "title": "Effort multiplier vs medium",
            "format": ".2f"
          },
          {
            "field": "selected_cost_credits",
            "type": "quantitative",
            "title": "Selected metric cost, credits",
            "format": ",.2f"
          },
          {
            "field": "baseline_cost_credits",
            "type": "quantitative",
            "title": "Baseline cost, credits",
            "format": ",.2f"
          },
          {
            "field": "relative_multiple",
            "type": "quantitative",
            "title": "Multiple of baseline",
            "format": ".2f"
          },
          {
            "field": "baseline_flag",
            "type": "nominal",
            "title": "Baseline"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "strokeDash": [
          4,
          4
        ]
      },
      "encoding": {
        "y": {
          "datum": 1,
          "type": "quantitative"
        },
        "tooltip": [
          {
            "value": "Baseline = 1.0x"
          }
        ]
      }
    }
  ],
  "config": {
    "axis": {
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": {
      "orient": "top"
    },
    "view": {
      "stroke": "transparent"
    }
  },
